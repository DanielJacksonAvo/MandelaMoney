<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="BlurPanel">
        <item name="android:background">@drawable/panel_background_shape</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="fontFamily">@font/dm_sans_medium</item>
    </style>

    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/mandelaBlue</item>
        <item name="backgroundTint">@color/mandelaYellow</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="FilterChip" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/grey10</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeColor">@color/white10</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">18dp</item>
    </style>
    <style name="SecondaryButton">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/white30</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="TertiaryButton">
        <item name="android:textColor">@color/mandelaBlue</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:textSize">10sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="HyperLinkButton">
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/hyperlinkbutton_textview_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:font">@font/dm_sans_medium</item>
    </style>

    <style name="TextBox" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/rounded_white_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textAlignment">center</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:height">45dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="InformationText">
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="DividerLine">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:background">@color/white30</item>
    </style>

    <style name="TitleText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TitleTextSmall">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">10sp</item>
    </style>



    <style name="BottomNavigationView.NoActiveIndicator" parent="Widget.MaterialComponents.BottomNavigationView.PrimarySurface">
        <item name="android:itemBackground">@drawable/bottom_nav_transparent_item_bg</item>
        <item name="itemRippleColor">@android:color/transparent</item>
    </style>
    <style name="AppPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/bg_pop_up_menu</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="DimLoadingScreen">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">#8D000000</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:elevation">999dp</item>
    </style>


</resources>