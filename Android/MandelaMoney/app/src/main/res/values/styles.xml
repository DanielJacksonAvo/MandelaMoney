<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="BaseButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="backgroundTint">@null</item> <item name="android:background">@drawable/button_background_rounded</item>
    </style>

    <style name="PrimaryButton" parent="BaseButton">
        <item name="android:background">@drawable/button_background_primary</item>
        <item name="android:textColor">#000000</item> </style>

    <style name="SecondaryButton" parent="BaseButton">
        <item name="android:background">@drawable/button_background_secondary</item>
        <item name="android:textColor">#000000</item> </style>

    <style name="AdditionalButton" parent="BaseButton">
        <item name="android:background">@drawable/button_background_additional</item>
        <item name="android:textColor">#000000</item> </style>

    <style name="BlurPanel">
        <item name="android:background">@drawable/panel_background_shape</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <drawable name="button_background_rounded">
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <solid android:color="@android:color/white"/> </shape>
    </drawable>

    <drawable name="button_background_primary">
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <solid android:color="#FFFF00"/> </shape>
    </drawable>

    <drawable name="button_background_secondary">
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <solid android:color="#FFFFFF"/> </shape>
    </drawable>

    <drawable name="button_background_additional">
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <solid android:color="#80FFFFFF"/> </shape>
    </drawable>

    <drawable name="panel_background_shape">
        <shape>
            <solid android:color="@color/white5" />
        <corners android:radius="24dp" />
        <stroke android:color="@color/white10"
            android:width="2dp" />
        </shape>
    </drawable>

</resources>